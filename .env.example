NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=YOUR_SANITY_PROJECT_ID
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-05-12
SANITY_READ_TOKEN=YOUR_SANITY_READ_TOKEN
SANITY_WEBHOOK_SECRET=YOUR_SANITY_WEBHOOK_SECRET
FORM_WEBHOOK_URL=YOUR_FORM_WEBHOOK_URL

# Policy: template placeholders only; never commit live secrets.


# Contact Form email delivery
# IMPORTANT: Copy this file to .env and set your real API key there. Never commit your real API key.
RESEND_API_KEY=YOUR_RESEND_API_KEY

# Cloudflare Turnstile (production only)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=YOUR_TURNSTILE_SITE_KEY
TURNSTILE_SECRET_KEY=YOUR_TURNSTILE_SECRET_KEY
NEXT_PUBLIC_TURNSTILE_ENABLED=false
TURNSTILE_ENABLED=false
